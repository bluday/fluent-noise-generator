<?xml version="1.0" encoding="utf-8" ?>
<Application x:Class="FluentNoiseGenerator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>

                <!-- Compact styles -->
                <ResourceDictionary Source="ms-appx:///Microsoft.UI.Xaml/DensityStyles/Compact.xaml"/>

                <!-- Infrastructure -->
                <ResourceDictionary Source="/FluentNoiseGenerator.Foundation.UI/Themes/Generic.xaml"/>

                <!-- Playback -->
                <ResourceDictionary Source="/FluentNoiseGenerator.Features.Playback.UI/Styles/PlaybackControlPanelStyle.xaml"/>
                <ResourceDictionary Source="/FluentNoiseGenerator.Features.Playback.UI/Styles/PlaybackTopBarStyle.xaml"/>

                <!-- Settings -->
                <ResourceDictionary Source="/FluentNoiseGenerator.Features.Settings.UI/Styles/SettingsSectionHeader.xaml"/>
                <ResourceDictionary Source="/FluentNoiseGenerator.Features.Settings.UI/Styles/SettingsTitleBar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>