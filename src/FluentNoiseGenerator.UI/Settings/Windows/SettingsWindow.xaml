<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="FluentNoiseGenerator.UI.Settings.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:communityToolkit="using:CommunityToolkit.WinUI"
        xmlns:communityToolkitControls="using:CommunityToolkit.WinUI.Controls"
        xmlns:controls="using:FluentNoiseGenerator.UI.Settings.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Settings"
        x:DefaultBindMode="OneWay"
        Closed="Window_Closed"
        mc:Ignorable="d">
    <Grid x:Name="LayoutRoot"
          Loaded="LayoutRoot_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <controls:SettingsTitleBar x:Name="TitleBar"
                                   Title="Fluent Noise Generator"
                                   Grid.Row="0"/>

        <Grid Grid.Row="1"
              MaxWidth="{ThemeResource FluentNoiseGeneratorSettingsWindowMaxWidth}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Margin="{ThemeResource FluentNoiseGeneratorSettingsWindowMainTextMargin}"
                       VerticalAlignment="Center"
                       FontSize="{ThemeResource FluentNoiseGeneratorSettingsWindowMainTextFontSize}"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Text="Settings"
                       TextLineBounds="Tight"/>

            <ScrollViewer Grid.Row="1"
                          Padding="{ThemeResource FluentNoiseGeneratorSettingsWindowContentPadding}">
                <StackPanel Orientation="Vertical"
                            Spacing="{ThemeResource FluentNoiseGeneratorSettingsWindowMainStackPanelSpacing}">

                    <controls:SettingsGeneralSection Margin="{ThemeResource FluentNoiseGeneratorSettingsWindowSectionStackPanelMargin}"
                                                     AvailableLanguages="{x:Bind ViewModel.AvailableLanguages}"
                                                     AvailableNoisePresets="{x:Bind ViewModel.AvailableNoisePresets}"
                                                     SelectedDefaultNoisePreset="{x:Bind ViewModel.SelectedDefaultNoisePreset, Mode=TwoWay}"
                                                     SelectedLanguage="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"/>

                    <controls:SettingsSoundSection AvailableAudioSampleRates="{x:Bind ViewModel.AvailableAudioSampleRates}"
                                                   SelectedAudioSampleRate="{x:Bind ViewModel.SelectedAudioSampleRate, Mode=TwoWay}"/>

                    <controls:SettingsAppearanceSection AvailableApplicationThemes="{x:Bind ViewModel.AvailableApplicationThemes}"
                                                        AvailableSystemBackdrops="{x:Bind ViewModel.AvailableSystemBackdrops}"
                                                        SelectedApplicationTheme="{x:Bind ViewModel.SelectedApplicationTheme, Mode=TwoWay}"
                                                        SelectedSystemBackdrop="{x:Bind ViewModel.SelectedSystemBackdrop, Mode=TwoWay}"/>

                    <controls:SettingsAboutSection/>

                    <StackPanel Margin="{ThemeResource FluentNoiseGeneratorSettingsWindowFooterStackPanelMargin}"
                                Spacing="{ThemeResource FluentNoiseGeneratorSettingsWindowFooterStackPanelSpacing}">
                        <HyperlinkButton x:Uid="/SettingsWindow/HyperlinkButtons/RepositoryOnGitHub"
                                         Padding="{ThemeResource FluentNoiseGeneratorSettingsWindowHyperlinkButtonPadding}"/>

                        <HyperlinkButton x:Uid="/SettingsWindow/HyperlinkButtons/SendFeedback"
                                         Padding="{ThemeResource FluentNoiseGeneratorSettingsWindowHyperlinkButtonPadding}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>