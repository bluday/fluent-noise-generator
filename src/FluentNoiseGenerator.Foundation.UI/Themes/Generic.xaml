<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Playback -->
    <CornerRadius x:Key="FluentNoiseGeneratorPlaybackControlPanelPlaybackButtonCornerRadius">40</CornerRadius>
    <CornerRadius x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="FluentNoiseGeneratorPlaybackTopBarDragHandleCornerRadius">2</CornerRadius>

    <SolidColorBrush x:Key="FluentNoiseGeneratorPlaybackControlPanelButtonBackgroundBrush"
                     Color="Transparent"/>
    <SolidColorBrush x:Key="FluentNoiseGeneratorPlaybackControlPanelButtonBorderBrush"
                     Color="Transparent"/>
    <SolidColorBrush x:Key="FluentNoiseGeneratorPlaybackTopBarDragHandleBackgroundBrush"
                     Color="{ThemeResource ControlStrongFillColorDefault}"/>

    <StaticResource x:Key="FluentNoiseGeneratorPlaybackTopBarBorderBrush"
                    ResourceKey="ControlElevationBorderBrush"/>

    <Thickness x:Key="FluentNoiseGeneratorPlaybackControlPanelButtonBorderThickness">0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackControlPanelButtonPadding">8</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetItemMargin">4,8</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetsHeaderMargin">0,0,0,8</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackTopBarBorderThickness">0,0,0,1</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackTopBarButtonPadding">0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackTopBarDragHandleBorderThickness">0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorPlaybackTopBarPadding">4</Thickness>

    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelButtonSize">32</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelHeaderFontSize">16</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelPlaybackButtonSize">48</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetColorSize">24</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetItemSpacing">12</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetsFlyoutWidth">200</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelSpacing">8</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelVolumeFlyoutSpacing">10</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelVolumeSliderWidth">150</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackControlPanelVolumeValueWidth">32</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackTopBarButtonSize">22</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackTopBarCloseButtonFontSize">10</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackTopBarDragHandleHeight">3</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackTopBarDragHandleWidth">32</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorPlaybackTopBarSettingsButtonFontSize">14</x:Double>

    <x:Boolean x:Key="FluentNoiseGeneratorPlaybackControlPanelFlyoutAnimationsEnabled">True</x:Boolean>
    <x:Boolean x:Key="FluentNoiseGeneratorPlaybackControlPanelFlyoutConstrainToRootBounds">False</x:Boolean>

    <x:String x:Key="FluentNoiseGeneratorPlaybackControlPanelPauseGlyph">&#xf8ae;</x:String>
    <x:String x:Key="FluentNoiseGeneratorPlaybackControlPanelPlayGlyph">&#xf5b0;</x:String>
    <x:String x:Key="FluentNoiseGeneratorPlaybackControlPanelPresetsGlyph">&#xf61f;</x:String>
    <x:String x:Key="FluentNoiseGeneratorPlaybackControlPanelVolumeGlyph">&#xe767;</x:String>
    <x:String x:Key="FluentNoiseGeneratorPlaybackTopBarCloseButtonGlyph">&#xe8bb;</x:String>
    <x:String x:Key="FluentNoiseGeneratorPlaybackTopBarSettingsButtonGlyph">&#xe713;</x:String>

    <!-- Settings -->
    <Thickness x:Key="FluentNoiseGeneratorSettingsSectionHeaderIconMargin">0,0,8,0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsSectionHeaderMargin">0,4</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsTitleBarIconMargin">8,4</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsWindowContentPadding">32,0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsWindowHyperlinkButtonPadding">0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsWindowMainTextMargin">32,24,32,16</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsWindowSectionStackPanelMargin">0,8,0,0</Thickness>
    <Thickness x:Key="FluentNoiseGeneratorSettingsWindowFooterStackPanelMargin">0,8,0,32</Thickness>

    <x:Double x:Key="FluentNoiseGeneratorSettingsSectionHeaderFontSize">14</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsSectionHeaderIconSize">16</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsTitleBarFontSize">12</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsTitleBarHeight">32</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsTitleBarIconSize">16</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsWindowFooterStackPanelSpacing">8</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsWindowMainStackPanelSpacing">16</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsWindowMainTextFontSize">24</x:Double>
    <x:Double x:Key="FluentNoiseGeneratorSettingsWindowMaxWidth">800</x:Double>

    <x:String x:Key="FluentNoiseGeneratorSettingsTitleBarIconSource">ms-appx:///Assets/Icon-64.ico</x:String>
</ResourceDictionary>